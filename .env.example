# Meraki frontend + indexer shared environment example
NEXT_PUBLIC_LIVE_DATA_ENABLED="false"
NEXT_PUBLIC_API_BASE="http://localhost:8787"
NEXT_PUBLIC_API_TIMEOUT_MS="2000"
NEXT_PUBLIC_SUMMARY_SNAPSHOT_URL="/snapshots/discovery-summary.v1.json"
NEXT_PUBLIC_TEST_MODE="true"
NEXT_PUBLIC_DEBUG_LOGS="true"

# Indexer / backend (consumed outside Next.js but stored here for reference)
DATABASE_URL="postgres://meraki:meraki@localhost:5432/meraki_dev"
INDEXER_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
INDEXER_CHAIN_ID="11155111"

# Feature flags
NEXT_PUBLIC_FEATURE_ENABLE_BUY="false"
NEXT_PUBLIC_FEATURE_ENABLE_SELL="false"
NEXT_PUBLIC_FEATURE_ENABLE_MIGRATION="false"
NEXT_PUBLIC_FEATURE_ENABLE_REWARDS="false"
NEXT_PUBLIC_BUY_ENABLED="false"
NEXT_PUBLIC_BUY_TESTNET_ONLY="true"
NEXT_PUBLIC_BUY_CHAIN_ID="11155111"
NEXT_PUBLIC_BUY_MAX_NATIVE_AMOUNT="10000000000000000"
# Protected Slice 3 staging only. Comma-separated public addresses; empty fails closed.
NEXT_PUBLIC_BUY_ALLOWED_WALLETS=""
NEXT_PUBLIC_TOKEN_CREATION_ENABLED="false"
NEXT_PUBLIC_TOKEN_CREATION_TESTNET_ONLY="true"
NEXT_PUBLIC_TOKEN_CREATION_CHAIN_ID="11155111"
# Controlled Preview restriction only; not a production security boundary.
NEXT_PUBLIC_TOKEN_CREATION_ALLOWED_WALLETS=""
NEXT_PUBLIC_SELL_ENABLED="false"
NEXT_PUBLIC_REWARDS_ENABLED="false"
NEXT_PUBLIC_CLAIMS_ENABLED="false"
