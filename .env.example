# Meraki frontend + indexer shared environment example
NEXT_PUBLIC_API_BASE="http://localhost:8787"
NEXT_PUBLIC_SUMMARY_SNAPSHOT_URL="/api_summary_latest.json"
NEXT_PUBLIC_TEST_MODE="true"
NEXT_PUBLIC_DEBUG_LOGS="true"

# Indexer / backend (consumed outside Next.js but stored here for reference)
DATABASE_URL="postgres://meraki:meraki@localhost:5432/meraki_dev"
INDEXER_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
INDEXER_CHAIN_ID="11155111"

# Feature flags
FEATURE_ENABLE_BUY="false"
FEATURE_ENABLE_SELL="false"
FEATURE_ENABLE_MIGRATION="false"
FEATURE_ENABLE_REWARDS="false"
